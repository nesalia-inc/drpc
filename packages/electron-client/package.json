{
  "name": "@deessejs/electron-client",
  "version": "1.0.0",
  "type": "module",
  "description": "Type-safe RPC client for Electron renderer process",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@deessejs/fp": "^3.0.0"
  },
  "peerDependencies": {
    "@deessejs/server": "*"
  },
  "devDependencies": {
    "@deessejs/server": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
